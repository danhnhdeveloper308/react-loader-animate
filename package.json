{
  "name": "react-loader-animate",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "build:lib": "tsup && tsc --project tsconfig.lib.json",
    "build:css": "tailwindcss --config tailwind.lib.config.ts -i src/lib/styles.css -o dist/style.css --minify",
    "build": "npm run build:lib && npm run build:css",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.4.0",
    "postcss": "^8.5.6",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  },
  "description": "41+ beautiful, performant React loading animation components",
  "keywords": [
    "react",
    "loader",
    "animation",
    "spinner",
    "loading",
    "typescript"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./tailwind.preset": "./tailwind.preset.ts"
  },
  "files": [
    "dist",
    "tailwind.preset.ts"
  ]
}